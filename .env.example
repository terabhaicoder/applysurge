# ============================================
# APPLICATION
# ============================================
APP_NAME=JobPilot
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-chars
ENCRYPTION_KEY=change-me-32-byte-encryption-key-here

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
DOMAIN=localhost

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql+asyncpg://jobpilot:jobpilot_pass@postgres:5432/jobpilot_db
POSTGRES_USER=jobpilot
POSTGRES_PASSWORD=jobpilot_pass
POSTGRES_DB=jobpilot_db

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# RABBITMQ
# ============================================
RABBITMQ_URL=amqp://jobpilot:rabbitmq_pass@rabbitmq:5672/
RABBITMQ_DEFAULT_USER=jobpilot
RABBITMQ_DEFAULT_PASS=rabbitmq_pass

# ============================================
# JWT & AUTH
# ============================================
JWT_SECRET_KEY=change-me-jwt-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# AI / LLM
# ============================================
LLM_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# EMAIL SERVICES
# ============================================
SENDGRID_API_KEY=

# Email finding & verification
HUNTER_API_KEY=
ZEROBOUNCE_API_KEY=

# ============================================
# FILE STORAGE (S3-compatible)
# ============================================
AWS_S3_BUCKET=jobpilot-files
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION=us-east-1
S3_ENDPOINT_URL=http://minio:9000
STORAGE_BACKEND=local

# ============================================
# STRIPE (PAYMENTS)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# SMTP (Transactional emails)
# ============================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@jobpilot.com
SMTP_FROM_NAME=JobPilot

# ============================================
# BROWSER AUTOMATION
# ============================================
PLAYWRIGHT_HEADLESS=true
BROWSER_TIMEOUT_MS=30000
MAX_CONCURRENT_BROWSERS=3

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# ============================================
# CELERY (Task Queue)
# ============================================
CELERY_BROKER_URL=amqp://jobpilot:rabbitmq_pass@rabbitmq:5672/
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_CONCURRENCY=4

# ============================================
# AGENT SETTINGS (Defaults)
# ============================================
DEFAULT_DAILY_APPLICATION_LIMIT=25
DEFAULT_COOLDOWN_SECONDS=30
DEFAULT_MIN_MATCH_SCORE=70

# ============================================
# BETA LIMITS
# ============================================
BETA_MAX_TOTAL_APPLICATIONS=10
ADMIN_EMAILS=paarth.paan3@gmail.com

# ============================================
# PRODUCTION (only needed in prod)
# ============================================
# ACME_EMAIL=your-email@example.com
# REDIS_PASSWORD=your-redis-password
