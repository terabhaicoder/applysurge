# ============================================
# APPLY SURGE — Production Environment
# Copy this to .env on your server and fill in values
# ============================================

# APPLICATION
APP_NAME=ApplySurge
APP_ENV=production
DEBUG=false
SECRET_KEY=GENERATE_WITH: openssl rand -hex 32
ENCRYPTION_KEY=GENERATE_WITH: openssl rand -base64 32
ENVIRONMENT=production

# DOMAIN — change to your actual domain
DOMAIN=applysurge.com
FRONTEND_URL=https://applysurge.com
BACKEND_URL=https://api.applysurge.com
ACME_EMAIL=paarth.paan3@gmail.com

# DATABASE
DATABASE_URL=postgresql+asyncpg://applysurge:CHANGE_THIS_DB_PASSWORD@postgres:5432/applysurge_db
POSTGRES_USER=applysurge
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD
POSTGRES_DB=applysurge_db

# REDIS
REDIS_URL=redis://redis:6379/0

# RABBITMQ
RABBITMQ_URL=amqp://applysurge:CHANGE_THIS_MQ_PASSWORD@rabbitmq:5672/
RABBITMQ_DEFAULT_USER=applysurge
RABBITMQ_DEFAULT_PASS=CHANGE_THIS_MQ_PASSWORD

# JWT
JWT_SECRET_KEY=GENERATE_WITH: openssl rand -hex 32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — your frontend domain
CORS_ORIGINS=https://applysurge.com,https://www.applysurge.com

# AI / LLM
LLM_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# CELERY
CELERY_BROKER_URL=amqp://applysurge:CHANGE_THIS_MQ_PASSWORD@rabbitmq:5672/
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_CONCURRENCY=2

# STORAGE
STORAGE_BACKEND=local

# BROWSER
PLAYWRIGHT_HEADLESS=true
BROWSER_TIMEOUT_MS=30000
MAX_CONCURRENT_BROWSERS=1

# AGENT
DEFAULT_DAILY_APPLICATION_LIMIT=25
DEFAULT_COOLDOWN_SECONDS=30
DEFAULT_MIN_MATCH_SCORE=70

# BETA
BETA_MAX_TOTAL_APPLICATIONS=10
ADMIN_EMAILS=paarth.paan3@gmail.com

# SMTP (optional — skip if not sending emails yet)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@applysurge.com
SMTP_FROM_NAME=Apply Surge

# LEAVE EMPTY FOR NOW (not needed for demo)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SENDGRID_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
HUNTER_API_KEY=
ZEROBOUNCE_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
